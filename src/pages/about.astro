---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import Button from '../components/Button.astro';
---

<Layout
  title="About — Whyte Contracting"
  description="Established in 2022, Whyte Contracting LLC is a heavy-haul dump truck and residential construction firm in Copiague, NY. Our mission, vision, and values."
>

  <Nav currentPath={Astro.url.pathname} />

  <!-- ─── PAGE HEADER ─── -->
  <section class="page-header" aria-label="About Whyte Contracting">
    <div class="container page-header-inner">
      <p class="label label--green">About Us</p>
      <h1 class="page-headline">Geared for success<br />since 2022.</h1>
      <p class="page-sub">
        A heavy-haul dump truck and residential construction firm built on honesty,
        reliability, and work that speaks for itself.
      </p>
    </div>
  </section>

  <!-- ─── PAGE SECTIONS NAV ─── -->
  <nav class="page-nav" aria-label="Page sections">
    <div class="container page-nav-inner">
      <div class="page-nav-links">
        <a href="#our-story" class="page-nav-link">Our Story</a>
        <a href="#mission-vision" class="page-nav-link">Mission &amp; Vision</a>
        <a href="#values" class="page-nav-link">Values</a>
      </div>
      <a href="/contact" class="page-nav-contact">Get in Touch →</a>
    </div>
  </nav>

  <!-- ─── COMPANY INTRO ─── -->
  <section class="intro" id="our-story" aria-labelledby="intro-heading">
    <div class="container intro-inner">
      <div class="intro-text">
        <h2 id="intro-heading">Whyte Contracting LLC</h2>
        <p>
          Founded in 2022 and headquartered in Copiague, NY, Whyte Contracting LLC specializes
          in heavy-haul dump trucking and residential construction across Long Island. We serve
          homeowners, contractors, and developers who demand quality, punctuality, and
          straight talk, no runaround.
        </p>
        <p>
          Whether we're hauling materials to a job site, clearing debris, or delivering a
          full home remodel, our standard doesn't change: best-in-class customer service,
          quality workmanship, and maximum productivity on every project.
        </p>
      </div>
      <div class="intro-stat-col">
        <div class="stat-block">
          <span class="stat-number">2022</span>
          <span class="stat-label">Established</span>
        </div>
        <div class="stat-block">
          <span class="stat-number">LI</span>
          <span class="stat-label">Long Island based</span>
        </div>
        <div class="stat-block">
          <span class="stat-number">2</span>
          <span class="stat-label">Core services</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── PHOTO STRIP ─── -->
  <div class="photo-strip" role="presentation">
    <img
      src="https://images.unsplash.com/photo-1541888946425-d81bb19240f5?auto=format&fit=crop&w=2000&q=80"
      alt="Construction crew working on a Long Island job site"
      loading="lazy"
      width="2000"
      height="640"
    />
  </div>

  <!-- ─── MISSION & VISION ─── -->
  <section class="mv" id="mission-vision" aria-labelledby="mv-heading">
    <div class="container">
      <header class="section-header mv-header">
        <h2 id="mv-heading">What drives us</h2>
      </header>
      <div class="mv-grid">

        <article class="mv-card" aria-labelledby="mission-heading">
          <h3 id="mission-heading">Mission</h3>
          <p>
            To provide quality services to our clients that will help their companies
            prosper and grow: delivered with honesty, efficiency, and care.
          </p>
        </article>

        <article class="mv-card" aria-labelledby="vision-heading">
          <h3 id="vision-heading">Vision</h3>
          <p>
            To be the most trusted and reliable heavy-haul transportation provider in
            the region, consistently delivering efficient and safe dumping services and
            residential remodeling, prioritizing customer satisfaction, and contributing
            to the success of construction projects through innovative solutions and a
            commitment to environmental responsibility.
          </p>
        </article>

      </div>
    </div>
  </section>

  <!-- ─── VALUES ─── -->
  <section class="values" id="values" aria-labelledby="values-heading">
    <div class="container">
      <header class="section-header">
        <h2 id="values-heading">What we stand for</h2>
      </header>
      <div class="values-grid">

        <article class="value-tile" aria-label="Integrity">
          <h3 class="value-name">Integrity</h3>
          <p class="value-desc">We say what we mean and do what we say — every time, no exceptions.</p>
        </article>

        <article class="value-tile" aria-label="Loyalty">
          <h3 class="value-name">Loyalty</h3>
          <p class="value-desc">Our clients and crews can count on us to show up and follow through.</p>
        </article>

        <article class="value-tile" aria-label="Respect">
          <h3 class="value-name">Respect</h3>
          <p class="value-desc">We treat every property, every client, and every job site with care.</p>
        </article>

      </div>
    </div>
  </section>

  <!-- ─── CLOSING CTA ─── -->
  <section class="cta" aria-labelledby="cta-heading">
    <div class="container cta-inner">
      <p class="label label--accent">Work With Us</p>
      <h2 id="cta-heading" class="cta-headline">Ready to get to work?</h2>
      <p class="cta-sub">Reach out and we'll get back to you the same day.</p>
      <Button href="/contact" ariaLabel="Go to contact page">Get in Touch</Button>
    </div>
  </section>

  <button class="back-to-top" aria-label="Scroll back to top">↑</button>

  <Footer />

</Layout>

<style>
  .container {
    max-width: var(--max-w);
    margin: 0 auto;
    padding: 0 var(--gutter);
  }

  .label {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    margin-bottom: var(--space-sm);
  }

  .label--dark   { color: var(--c-muted); }
  .label--green  { color: var(--c-accent-on-dark); }
  .label--accent { color: var(--c-accent); }

  /* ─── Page Header ─── */
  .page-header {
    background: var(--c-dark);
    padding: calc(var(--space-section) + 4rem) 0 var(--space-section);
  }

  .page-header-inner {
    max-width: 820px;
  }

  .page-headline {
    font-size: clamp(3rem, 7vw, 5.5rem);
    font-weight: 700;
    line-height: 0.97;
    letter-spacing: -0.03em;
    color: var(--c-on-dark);
    margin-bottom: var(--space-lg);
    margin-top: var(--space-xs);
  }

  .page-sub {
    font-size: clamp(0.95rem, 1.5vw, 1.1rem);
    color: var(--c-on-dark-soft);
    max-width: 52ch;
    line-height: 1.65;
  }

  /* ─── Intro ─── */
  .intro {
    padding: var(--space-section) 0;
    background: var(--c-canvas);
  }

  .intro-inner {
    display: grid;
    grid-template-columns: 1fr 280px;
    gap: clamp(3rem, 6vw, 6rem);
    align-items: start;
  }

  .intro-text h2 {
    font-size: clamp(1.75rem, 3vw, 2.5rem);
    font-weight: 700;
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: var(--c-ink);
    margin-bottom: var(--space-lg);
    margin-top: var(--space-xs);
  }

  .intro-text p {
    font-size: 1rem;
    color: var(--c-body);
    line-height: 1.7;
    max-width: 60ch;
  }

  .intro-text p + p {
    margin-top: var(--space-lg);
  }

  .intro-stat-col {
    display: flex;
    flex-direction: column;
    gap: var(--space-2xl);
  }

  .stat-block {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    padding-top: var(--space-sm);
    border-top: 2px solid var(--c-hairline);
  }

  .stat-number {
    font-size: 2rem;
    font-weight: 700;
    color: var(--c-accent);
    letter-spacing: -0.03em;
    line-height: 1;
  }

  .stat-label {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--c-muted);
  }

  /* ─── Mission / Vision ─── */
  .mv {
    padding: clamp(3rem, 5.5vw, 5.5rem) 0;
    background: var(--c-canvas-tinted);
    border-top: 1px solid var(--c-hairline);
    border-bottom: 1px solid var(--c-hairline);
  }

  .mv > .container > .section-header {
    margin-bottom: clamp(2rem, 4vw, 3.5rem);
  }

  .mv-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(2rem, 4vw, 4rem);
  }

  .mv-card {
    padding: var(--space-2xl) 0;
    border-top: 2px solid var(--c-hairline);
  }

  .mv-card h3 {
    font-size: clamp(1.25rem, 2vw, 1.75rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--c-ink);
    margin-bottom: var(--space-lg);
  }

  .mv-card p {
    font-size: 0.9375rem;
    color: var(--c-body);
    line-height: 1.7;
  }

  /* ─── Values ─── */
  .values {
    padding: var(--space-section) 0;
    background: var(--c-canvas);
  }

  .section-header {
    margin-bottom: clamp(2.5rem, 5vw, 4rem);
  }

  .section-header h2 {
    font-size: clamp(1.75rem, 3.5vw, 2.75rem);
    font-weight: 700;
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: var(--c-ink);
  }

  .values-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0;
    border-top: 2px solid var(--c-ink);
  }

  .value-tile {
    padding: var(--space-2xl) var(--space-2xl) var(--space-2xl) 0;
    border-right: 1px solid var(--c-hairline);
  }

  .value-tile:not(:first-child) {
    padding-left: var(--space-2xl);
  }

  .value-tile:last-child {
    border-right: none;
    padding-right: 0;
  }

  .value-name {
    font-size: clamp(1.5rem, 2.5vw, 2rem);
    font-weight: 700;
    letter-spacing: -0.025em;
    color: var(--c-ink);
    margin-bottom: var(--space-md);
  }

  .value-desc {
    font-size: 0.9375rem;
    color: var(--c-body);
    line-height: 1.65;
    max-width: 30ch;
  }

  /* ─── Photo Strip ─── */
  .photo-strip {
    height: clamp(220px, 25vw, 440px);
    overflow: hidden;
  }

  .photo-strip img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 60%;
  }

  /* ─── Closing CTA ─── */
  .cta {
    padding: clamp(2.5rem, 4vw, 4.5rem) 0;
    background: var(--c-canvas-tinted);
    border-top: 3px solid var(--c-accent);
  }

  .cta-inner {
    max-width: 640px;
  }

  .cta-headline {
    font-size: clamp(2rem, 4vw, 3.25rem);
    font-weight: 700;
    line-height: 1.05;
    letter-spacing: -0.025em;
    color: var(--c-ink);
    margin-bottom: var(--space-md);
    margin-top: var(--space-xs);
  }

  .cta-sub {
    font-size: 1rem;
    color: var(--c-body);
    margin-bottom: var(--space-2xl);
    max-width: 42ch;
  }

  /* ─── Responsive ─── */
  @media (max-width: 820px) {
    .intro-inner {
      grid-template-columns: 1fr;
    }

    .intro-stat-col {
      flex-direction: row;
      flex-wrap: wrap;
      padding-top: 0;
      gap: var(--space-xl);
    }

    .mv-grid {
      grid-template-columns: 1fr;
    }
  }

  /* ─── Page Sections Nav ─── */
  .page-nav {
    background: var(--c-dark-elevated);
    border-bottom: 1px solid var(--c-overlay);
  }

  .page-nav-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: var(--space-sm);
    padding-bottom: var(--space-sm);
  }

  .page-nav-links {
    display: flex;
    align-items: center;
  }

  .page-nav-link {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--c-on-dark-soft);
    padding: 0.5rem 0.75rem;
    position: relative;
    transition: color 0.15s ease-out;
    white-space: nowrap;
  }

  .page-nav-link::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0.75rem;
    right: 0.75rem;
    height: 2px;
    background: var(--c-accent-on-dark);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.2s ease-out;
  }

  .page-nav-link:hover,
  .page-nav-link.is-active {
    color: var(--c-on-dark);
  }

  .page-nav-link:hover::after,
  .page-nav-link.is-active::after {
    transform: scaleX(1);
  }

  .page-nav-link:focus-visible {
    outline: 2px solid var(--c-accent-on-dark);
    outline-offset: -2px;
  }

  .page-nav-contact {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--c-accent-on-dark);
    flex-shrink: 0;
    transition: color 0.15s ease-out;
  }

  .page-nav-contact:hover {
    color: var(--c-on-dark);
  }

  /* ─── Scroll margin for fixed nav ─── */
  #our-story,
  #mission-vision,
  #values {
    scroll-margin-top: 5rem;
  }

  /* ─── Back to Top ─── */
  .back-to-top {
    position: fixed;
    bottom: var(--space-xl);
    right: var(--space-xl);
    z-index: 90;
    width: 44px;
    height: 44px;
    background: var(--c-dark);
    color: var(--c-on-dark);
    border: 1px solid oklch(100% 0 0 / 0.12);
    font-size: 1rem;
    font-family: var(--font);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transform: translateY(8px);
    transition: opacity 0.25s ease-out, transform 0.25s ease-out, background 0.15s ease-out;
    pointer-events: none;
  }

  .back-to-top.is-visible {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
  }

  .back-to-top:hover {
    background: var(--c-accent);
  }

  .back-to-top:focus-visible {
    outline: 2px solid var(--c-accent-on-dark);
    outline-offset: 3px;
  }

  @media (max-width: 680px) {
    .values-grid {
      grid-template-columns: 1fr;
    }

    .value-tile,
    .value-tile:not(:first-child),
    .value-tile:last-child {
      border-right: none;
      border-bottom: 1px solid var(--c-hairline);
      padding: var(--space-xl) 0;
    }

    .value-tile:last-child {
      border-bottom: none;
    }

    .page-nav-contact {
      display: none;
    }

    .page-nav-link {
      font-size: 0.6875rem;
      padding: 0.5rem 0.5rem;
    }

    .back-to-top {
      bottom: var(--space-lg);
      right: var(--space-lg);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .back-to-top {
      transition: opacity 0.2s ease-out;
      transform: none;
    }
    .back-to-top.is-visible {
      transform: none;
    }
  }
</style>

<script>
  // Back-to-top button
  const backBtn = document.querySelector<HTMLButtonElement>('.back-to-top');
  if (backBtn) {
    const toggleBack = () => backBtn.classList.toggle('is-visible', window.scrollY > 300);
    toggleBack();
    window.addEventListener('scroll', toggleBack, { passive: true });
    backBtn.addEventListener('click', () => window.scrollTo({ top: 0, behavior: 'smooth' }));
  }

  // Active section highlighting
  const navLinks = document.querySelectorAll<HTMLAnchorElement>('.page-nav-link');
  if (navLinks.length) {
    const sections = Array.from(navLinks)
      .map(l => document.querySelector(l.getAttribute('href')!))
      .filter(Boolean) as Element[];

    const sectionObserver = new IntersectionObserver(
      entries => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            navLinks.forEach(l =>
              l.classList.toggle('is-active', l.getAttribute('href') === `#${entry.target.id}`)
            );
          }
        });
      },
      { rootMargin: '-15% 0px -75% 0px' }
    );

    sections.forEach(s => sectionObserver.observe(s));
  }
</script>
