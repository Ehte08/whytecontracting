---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import Button from '../components/Button.astro';

const phone     = '(631) 933-0772';
const phoneHref = 'tel:6319330772';
---

<Layout title="Whyte Contracting — Geared for Success">
  <link
    slot="head"
    rel="preload"
    as="image"
    href="https://images.unsplash.com/photo-1504307651254-35680f356dfd?auto=format&fit=crop&w=2000&q=80"
    fetchpriority="high"
  />

  <Nav currentPath={Astro.url.pathname} />

  <!-- ─── HERO ─── -->
  <section class="hero" aria-label="Introduction">
    <div class="hero-overlay" aria-hidden="true"></div>
    <div class="hero-inner">
      <p class="label" aria-hidden="true">Home Remodeling &nbsp;&middot;&nbsp; Dump Trucking</p>
      <h1 class="hero-headline">Geared for<br />success.</h1>
      <p class="hero-sub">
        Trusted contracting services for homeowners and job sites across Long Island.
      </p>
      <Button href="#services" ariaLabel="Check out our services" arrow="↓">
        Check out our services
      </Button>
    </div>
  </section>

  <!-- ─── SERVICES ─── -->
  <section class="services" id="services" aria-labelledby="services-heading">
    <div class="container">

      <header class="section-header">
        <h2 id="services-heading">What we do</h2>
      </header>

      <div class="services-grid">

        <article class="service-block" aria-labelledby="remodeling-title">
          <div class="service-photo">
            <img
              src="https://images.unsplash.com/photo-1601760561441-16420502c7e0?auto=format&fit=crop&w=1200&q=80"
              alt="Finished kitchen renovation with white cabinetry and modern appliances"
              loading="lazy"
              width="1200"
              height="800"
            />
          </div>
          <div class="service-text">
            <h3 id="remodeling-title">Home Remodeling</h3>
            <p>From kitchen renovations to full home remodels, we deliver quality craftsmanship that lasts. Honest pricing, clean work, no shortcuts.</p>
          </div>
        </article>

        <article class="service-block" aria-labelledby="trucking-title">
          <div class="service-photo">
            <img
              src="https://images.unsplash.com/photo-1653924333410-0dda83ae490c?auto=format&fit=crop&w=1200&q=80"
              alt="Two construction trucks parked on a job site at the end of the day"
              loading="lazy"
              width="1200"
              height="800"
            />
          </div>
          <div class="service-text">
            <h3 id="trucking-title">Dump Trucking</h3>
            <p>Reliable dump truck services for homeowners and contractors. Materials delivered, debris hauled, schedules met.</p>
          </div>
        </article>

      </div>
    </div>
  </section>

  <!-- ─── CONTACT CTA ─── -->
  <section class="contact" id="contact" aria-labelledby="contact-heading">
    <div class="container contact-inner">
      <h2 id="contact-heading" class="contact-headline">Ready to get started?</h2>
      <p class="contact-sub">Call or fill out our contact form and we'll get back to you the same day.</p>
      <div class="contact-actions">
        <Button href={phoneHref} ariaLabel={`Call us at ${phone}`} arrow="" class="btn--lg">
          Call Now
        </Button>
        <a href="/contact" class="contact-link" aria-label="Open contact form">
          Send a message
        </a>
      </div>
    </div>
  </section>

  <Footer />

</Layout>

<style>
  /* ─── Shared ─── */
  .container {
    max-width: var(--max-w);
    margin: 0 auto;
    padding: 0 var(--gutter);
  }

  .label {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--c-on-dark-soft);
    margin-bottom: var(--space-sm);
  }

  .label--dark  { color: var(--c-muted); }
  .label--green { color: var(--c-accent-on-dark); }

  /* ─── Hero ─── */
  .hero {
    position: relative;
    min-height: 100svh;
    display: flex;
    align-items: flex-end;
    padding: 7rem var(--gutter) var(--space-section);
    background-image: url('https://images.unsplash.com/photo-1504307651254-35680f356dfd?auto=format&fit=crop&w=2000&q=80');
    background-size: cover;
    background-position: center 40%;
    background-color: var(--c-dark);
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      135deg,
      oklch(17% 0.025 250 / 0.93) 0%,
      oklch(17% 0.025 250 / 0.78) 55%,
      oklch(17% 0.025 250 / 0.52) 100%
    );
  }

  .hero-inner {
    position: relative;
    z-index: 1;
    max-width: var(--max-w);
    width: 100%;
    margin: 0 auto;
  }

  .hero-headline {
    font-size: clamp(3.25rem, 8vw, 6.5rem);
    font-weight: 700;
    line-height: 0.97;
    letter-spacing: -0.03em;
    color: var(--c-on-dark);
    margin-bottom: var(--space-lg);
    margin-top: var(--space-xs);
  }

  .hero-sub {
    font-size: clamp(0.9rem, 1.5vw, 1.1rem);
    font-weight: 400;
    color: var(--c-on-dark-soft);
    max-width: 46ch;
    line-height: 1.6;
    margin-bottom: var(--space-xl);
  }

  /* ─── Services ─── */
  .services {
    padding: var(--space-section) 0;
    background: var(--c-canvas);
  }

  .section-header {
    margin-bottom: clamp(2.5rem, 5vw, 4rem);
  }

  .section-header h2 {
    font-size: clamp(1.75rem, 3.5vw, 2.75rem);
    font-weight: 700;
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: var(--c-ink);
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: clamp(2rem, 4vw, 4rem);
  }

  .service-block {
    transition: opacity 0.55s ease-out, transform 0.55s ease-out;
  }

  .service-block.will-animate {
    opacity: 0;
    transform: translateY(28px);
  }

  .service-block.will-animate:nth-child(2) {
    transition-delay: 0.12s;
  }

  .service-block.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  .service-photo {
    aspect-ratio: 4 / 3;
    overflow: hidden;
    background: var(--c-hairline);
    margin-bottom: var(--space-lg);
  }

  .service-photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease-out;
  }

  .service-block:hover .service-photo img {
    transform: scale(1.03);
  }

  .service-text h3 {
    font-size: clamp(1.1rem, 1.8vw, 1.35rem);
    font-weight: 700;
    color: var(--c-ink);
    letter-spacing: -0.01em;
    margin-bottom: var(--space-sm);
  }

  .service-text p {
    font-size: 0.9375rem;
    color: var(--c-body);
    max-width: 52ch;
    line-height: 1.65;
  }

  /* ─── Contact CTA ─── */
  .contact {
    padding: var(--space-section) 0;
    background: var(--c-dark);
  }

  .contact-inner {
    max-width: 640px;
  }

  .contact-headline {
    font-size: clamp(2rem, 4vw, 3.25rem);
    font-weight: 700;
    line-height: 1.05;
    letter-spacing: -0.025em;
    color: var(--c-on-dark);
    margin-bottom: var(--space-md);
    margin-top: var(--space-xs);
  }

  .contact-sub {
    font-size: 1rem;
    color: var(--c-on-dark-soft);
    margin-bottom: var(--space-2xl);
    max-width: 42ch;
  }

  .contact-actions {
    display: flex;
    align-items: center;
    gap: var(--space-xl);
    flex-wrap: wrap;
  }

  .btn--lg {
    font-size: 1.05rem;
    padding: 1rem 2.5rem;
  }

  .contact-link {
    font-size: 0.875rem;
    font-weight: 700;
    color: var(--c-on-dark-soft);
    letter-spacing: 0.03em;
    transition: color 0.15s ease-out;
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .contact-link:hover,
  .contact-link:focus-visible {
    color: var(--c-on-dark);
  }

  .contact-link:focus-visible {
    outline: 2px solid var(--c-accent);
    outline-offset: 3px;
  }

  /* ─── Responsive ─── */
  @media (max-width: 680px) {
    .services-grid {
      grid-template-columns: 1fr;
    }

    .contact-actions {
      flex-direction: column;
      align-items: flex-start;
      gap: var(--space-lg);
    }
  }

  /* ─── Reduced motion ─── */
  @media (prefers-reduced-motion: reduce) {
    .service-block {
      opacity: 1;
      transform: none;
      transition: none;
    }

    .service-photo img {
      transition: none;
    }
  }
</style>

<script>
  /* Service blocks: fade-in on scroll */
  const blocks = document.querySelectorAll<HTMLElement>('.service-block');

  const blockObserver = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
          blockObserver.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.12, rootMargin: '0px 0px -40px 0px' }
  );

  blocks.forEach((el) => {
    el.classList.add('will-animate');
    blockObserver.observe(el);
  });
</script>
