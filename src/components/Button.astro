---
interface Props {
  href?: string;
  type?: 'button' | 'submit' | 'reset';
  ariaLabel?: string;
  class?: string;
  arrow?: string;
}

const { href, type = 'button', ariaLabel, class: className, arrow = '→' } = Astro.props;
---

{href ? (
  <a href={href} class:list={['btn', className]} aria-label={ariaLabel}>
    <span class="btn-label"><slot /></span>
    <span class="btn-arrow" aria-hidden="true">{arrow}</span>
  </a>
) : (
  <button type={type} class:list={['btn', className]} aria-label={ariaLabel}>
    <span class="btn-label"><slot /></span>
    <span class="btn-arrow" aria-hidden="true">{arrow}</span>
  </button>
)}

<style>
  .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.9rem 2.25rem;
    background: var(--c-accent);
    color: var(--c-on-dark);
    font-family: var(--font);
    font-size: 0.875rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    line-height: 1;
    border: none;
    cursor: pointer;
    position: relative;
    overflow: hidden;
    transform: scale(1);
    transition:
      transform 0.25s cubic-bezier(0.4, 0, 0.2, 1),
      box-shadow 0.25s cubic-bezier(0.4, 0, 0.2, 1),
      background 0.2s ease-out;
    text-decoration: none;
  }

  /* Color sweep layer */
  .btn::before {
    content: '';
    position: absolute;
    inset: 0;
    background: var(--c-accent-hover);
    transform: translateX(-100%);
    transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    z-index: 0;
  }

  .btn-label,
  .btn-arrow {
    position: relative;
    z-index: 1;
  }

  .btn-arrow {
    display: inline-block;
    transition: transform 0.25s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .btn:hover {
    transform: scale(1.02);
    box-shadow: 0 6px 16px -8px oklch(35% 0.09 155 / 0.5);
  }

  .btn:hover::before {
    transform: translateX(0);
  }

  .btn:hover .btn-arrow {
    transform: translateX(4px);
  }

  .btn:active {
    transform: scale(0.99);
    box-shadow: none;
  }

  .btn:focus-visible {
    outline: 2px solid var(--c-accent);
    outline-offset: 3px;
  }

  @media (prefers-reduced-motion: reduce) {
    .btn {
      transition: background 0.2s ease-out;
    }

    .btn::before {
      display: none;
    }

    .btn-arrow {
      transition: none;
    }

    .btn:hover {
      transform: none;
      box-shadow: none;
      background: var(--c-accent-hover);
    }

    .btn:active {
      transform: none;
    }
  }
</style>
